
---
import { parseTableData } from '../../utils/parseTableData.js';

const { src, lang = 'ja' } = Astro.props;
let rows = [];
if (!src) {
    throw new Error('Table component requires a `src` prop pointing to src/data/tables/...');
}

// normalize to project-relative (no leading slash)
const relOrig = src.startsWith('/') ? src.slice(1) : src;

// derive dir, base, ext using string ops to avoid node imports in frontmatter
const lastSlash = relOrig.lastIndexOf('/');
const dir = lastSlash !== -1 ? relOrig.slice(0, lastSlash) : '.';
const fname = lastSlash !== -1 ? relOrig.slice(lastSlash + 1) : relOrig;
const lastDot = fname.lastIndexOf('.');
const base = lastDot !== -1 ? fname.slice(0, lastDot) : fname;
const ext = lastDot !== -1 ? fname.slice(lastDot) : '';

const candidates = [relOrig];
if (lang === 'en') {
    candidates.unshift(`${dir}/${base}.en${ext}`);
    candidates.unshift(`${dir}/en/${base}${ext}`);
    candidates.unshift(`${dir}/${base}_en${ext}`);
}

let parsed = false;
let lastErr = null;
for (const c of candidates) {
    try {
        rows = await parseTableData(c);
        parsed = true;
        break;
    } catch (e: any) {
        const msg = e && e.message ? e.message : String(e);
        // if file not found, try next candidate; otherwise rethrow
        if (msg.includes('Table data file not found')) {
            lastErr = e;
            continue;
        }
        throw e;
    }
}

if (!parsed) {
    const msg = lastErr && lastErr.message ? lastErr.message : 'unknown';
    throw new Error('Failed to parse table data: ' + msg);
}
---

<table class="table">
    {rows.length > 0 ? (
        <>
            <thead>
                <tr class="table__row">
                    {rows[0].map((h: any) => (
                        <th class="table__header">{h}</th>
                    ))}
                </tr>
            </thead>
            <tbody>
                {rows.slice(1).map((r: any) => (
                    <tr class="table__row">
                        {r.map((c: any) => (
                            <td class="table__cell">{c}</td>
                        ))}
                    </tr>
                ))}
            </tbody>
        </>
    ) : (
        <tbody>
            <tr class="table__row">
                <td class="table__cell">No data</td>
            </tr>
        </tbody>
    )}
</table>