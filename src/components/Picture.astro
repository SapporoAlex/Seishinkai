---
const {
  pcFile = "",
  spFile = "",
  fileName = "",
  baseDir: passedBaseDir,
} = Astro.props;

const isDev = import.meta.env.DEV;

// デフォルトのbaseDir
const defaultBaseDir = "/seishinkai/assets/images/";

// baseDirが渡っていれば使い、なければデフォルトを使う
const baseDir = passedBaseDir ?? defaultBaseDir;

function makeFullPath(file: string) {
  if (!file) return "";
  return file.startsWith("/") ? file : baseDir + file;
}

const pcImage = makeFullPath(pcFile);
const spImage = makeFullPath(spFile);
const fileImage = makeFullPath(fileName);

// 画像が1枚しかない場合
const noImage = !pcImage && !spImage;

function toWebp(path: string) {
  return path.replace(/\.(jpe?g|png)$/i, ".webp");
}
---

<picture>
  {
    isDev ? (
      <>
        {pcImage && <source media="(min-width: 768px)" srcset={pcImage} />}
        {spImage && <source media="(max-width: 767px)" srcset={spImage} />}
        <slot />
      </>
    ) : (
      <>
        {pcImage && (
          <source
            media="(min-width: 768px)"
            srcset={toWebp(pcImage)}
            type="image/webp"
          />
        )}
        {spImage && (
          <source
            media="(max-width: 767px)"
            srcset={toWebp(spImage)}
            type="image/webp"
          />
        )}
        {pcImage && <source media="(min-width: 768px)" srcset={pcImage} />}
        {spImage && <source media="(max-width: 767px)" srcset={spImage} />}
        {noImage && fileName && (
          <source srcset={toWebp(fileImage)} type="image/webp" />
        )}
        <slot />
      </>
    )
  }
</picture>
