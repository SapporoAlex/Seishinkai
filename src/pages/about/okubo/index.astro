          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/Dsc_4430.jpg"
              alt="沖縄での記念写真"
              loading="lazy"
            />
            <figcaption>沖縄</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/P4020023.jpg"
              alt="スウエーデンのタマス師範と"
              loading="lazy"
            />
            <figcaption>スウエーデン・タマス師範と</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/sri.jpg"
              alt="スリランカのササラシン師範と"
              loading="lazy"
            />
            <figcaption>スリランカ・ササラシン師範と</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/base/dalen.jpg"
              alt="オーストラリアのダレン師範と"
              loading="lazy"
            />
            <figcaption>オーストラリア・ダレン師範と</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/Dscn9659.jpg"
              alt="イタリアのサカバ師範と"
              loading="lazy"
            />
            <figcaption>イタリア・サカバ師範と</figcaption>
          </figure>
        </div>
      </div>

      <p class="detail-page__back">
        <a href="/about/">← 清心会について へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
