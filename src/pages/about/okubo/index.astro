              loading="lazy"
            />
            <figcaption>旧東京本部名札</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/1979.jpg"
              alt="大学時代の大久保勝美会長"
              loading="lazy"
            />
            <figcaption>大学時代</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/3.jpg"
              alt="大久保道場時代の稽古風景"
              loading="lazy"
            />
            <figcaption>大久保道場時代</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/4.jpg"
              alt="大久保道場時代の様子"
              loading="lazy"
            />
            <figcaption>大久保道場時代</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/Image1.jpg"
              alt="大学時代の演武"
              loading="lazy"
            />
            <figcaption>大学時代</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/semi.jpg"
              alt="平成24年夏の十段・宗師授与の様子"
              loading="lazy"
            />
            <figcaption>平成24年夏、十段・宗師授与</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/base/1999.jpg"
              alt="奥尻支部での記念写真"
              loading="lazy"
            />
            <figcaption>奥尻支部にて</figcaption>
          </figure>
          <figure>
            <img
              src="/assets/images/legacy/ok/Dscn1928.jpg"
