---
import BaseLayout from "@layouts/BaseLayout.astro";

const IMG = "/assets/images/legacy/komon/";
const CLUBU = "/assets/images/legacy/clubu/";

const advisors = [
  { name: "宮川敬浩", role: "北海道毎日文化協会理事長", image: `${IMG}miyakawa.jpg`, href: "https://www.facebook.com/profile.php?id=100015617839109" },
  { name: "森 成之", role: "北海道議会議員", image: `${IMG}miri-g.jpg`, href: "https://www.facebook.com/profile.php?id=100010477867334" },
  { name: "小林ゆうじ", role: "北海道議会議員", image: `${IMG}koba.jpg`, href: "https://www.facebook.com/yuji.kobayashi.71868" },
