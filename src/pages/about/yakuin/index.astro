  { title: "顧問", name: "丸山秀樹", role: "札幌市議会議員", image: `${IMG}maru-g.jpg`, href: "http://www.komei.or.jp/km/sapporo-maruyama-hideki/" },
  { title: "顧問", name: "五十嵐信子", role: "当別町議会議員", image: `${IMG}igarashi.jpg` },
];

const medicalAdvisors = [
