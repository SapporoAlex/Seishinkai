---
import BaseLayout from "@layouts/BaseLayout.astro";
import DojoCard from "@components/DojoCard.astro";
import DojoModal from "@components/DojoModal.astro";
import dojos from "@data/dojos.json";

// Group dojos by category
const directDojos = dojos.filter((d) => d.category === "direct");
const participatingDojos = dojos.filter((d) => d.category === "participating");
const affiliatedDojos = dojos.filter((d) => d.category === "affiliated");
---

<BaseLayout
  title="スケジュール・練習日程"
  description="清心会空手の各道場・クラスの練習日程一覧。札幌市内をはじめ、江別・岩見沢・石狩・恵庭・帯広など各地区の練習スケジュールをご確認いただけます。"
  lang="ja"
  path="/schedule/"
>
  <section class="schedule">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">SCHEDULE</span>
        <h1 class="section-title">空手道場・教室の稽古予定日</h1>
      </div>
      <p class="page-intro">
        札幌市を中心とする各地区での空手練習予定です。諸事により急遽、稽古がお休みになる場合は右欄の掲示板に案内を出して
        います(例:風雪害、コロナなど)。コロナの関係で会場の広さにより人数制限をしておりますので出稽古希望者は事前に担当支部
        長経由で確認後の参加となります。インフルエンザなどで学校閉鎖になった場合はお休みとなります。
      </p>

      <div class="schedule__card-group">
        <div class="schedule__card-left">
          <div class="schedule__card">
            <div class="cards-list__locations">
            <h2 class="cards-list__locations-title">札幌</h2>
            <ul class="cards-list__locations-list">
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate08.nikki.cmaker.jp/" target="_blank">白石区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate98.nikki.cmaker.jp/" target="_blank">厚別区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate2.dokkin.com/" target="_blank">中央区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate99.nikki.cmaker.jp/" target="_blank">豊平区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate3.dokkin.com/" target="_blank">清田区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate00.dokkin.com/" target="_blank">東区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate1.dokkin.com/" target="_blank">北区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate5.dokkin.com/" target="_blank">南区の空手教室</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate100.nikki.cmaker.jp/" target="_blank">★総本部一般部★</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate100.nikki.cmaker.jp/" target="_blank">★行事予定★</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate15.dokkin.com/" target="_blank">☆札幌居合部☆</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate15.dokkin.com/" target="_blank">★特別クラス★</a>
              </li>
              <li class="schedule__location">
                <a class="schedule__location-link" href="https://karate100.nikki.cmaker.jp/" target="_blank">★女性限定クラス★</a>
              </li>
            </ul>
            </div>
          </div>
          <div class="schedule__card">
            <div class="cards-list__locations">
              <h2 class="cards-list__locations-title">静岡県・福岡県</h2>
              <ul class="cards-list__locations-list">
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate12.dokkin.com/" target="_blank">予備2</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
        <div class="schedule__card-right">
          <div class="schedule__card">
            <div class="cards-list__locations">
              <h2 class="cards-list__locations-title">江別・岩見沢・石狩(花川空手)</h2>
              <ul class="cards-list__locations-list">
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate10.dokkin.com/" target="_blank">江別市の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate10.dokkin.com/" target="_blank">岩見沢市の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate14.dokkin.com/" target="_blank">石狩市の空手教室</a>
                </li>
              </ul>
            </div>
          </div>
          <div class="schedule__card">
            <div class="cards-list__locations">
              <h2 class="cards-list__locations-title">恵庭(島松)・帯広</h2>
              <ul class="cards-list__locations-list">
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate11.dokkin.com/" target="_blank">帯広市の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate9.dokkin.com/" target="_blank">恵庭市の空手教室</a>
                </li>
              </ul>
            </div>
          </div>
          <div class="schedule__card">
            <div class="cards-list__locations">
              <h2 class="cards-list__locations-title">当別・長沼・喜茂別・京極</h2>
              <ul class="cards-list__locations-list">
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate14.dokkin.com/" target="_blank">当別町の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate9.dokkin.com/" target="_blank">長沼町の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate11.dokkin.com/" target="_blank">喜茂別町の空手教室</a>
                </li>
                <li class="schedule__location">
                  <a class="schedule__location-link" href="https://karate11.dokkin.com/" target="_blank">京極町の空手教室</a>
                </li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
    

<!-- Dojo Cards Section -->
    <div class="schedule-dojos__container">
      <div class="layout__container">
        <div class="section__title-area inverse">
          <span class="section-label">DOJO LIST</span>
          <h2 class="section-title">清心会・清心流 道場一覧</h2>
        </div>

        
        <div class="schedule__dojos">
          <h2 class="schedule__dojos-title">清心会直系・公認道場/自主管理道場</h2>
          <p class="schedule__dojos-note">※練習日は下記をクリックして下さい</p>
          <div class="schedule__dojos-grid">
            {
              directDojos.map((dojo) => (
                <DojoCard
                  id={dojo.id}
                  name={dojo.name}
                  sensei={dojo.sensei}
                  category={dojo.category}
                />
              ))
            }
          </div>

          <h2 class="schedule__dojos-title">清心流参加道場・加盟道場</h2>
          <p class="schedule__dojos-note">※練習日時は下記へご確認ください</p>
          <div class="schedule__dojos-grid">
            {
              participatingDojos.map((dojo) => (
                <DojoCard
                  id={dojo.id}
                  name={dojo.name}
                  sensei={dojo.sensei}
                  category={dojo.category}
                />
              ))
            }
          </div>

          <h2 class="schedule__dojos-title">準加盟道場・提携協力道場</h2>
          <p class="schedule__dojos-note">
            ※練習日時は下記へご確認下さい。運営活動関係等は直接道場へ。
          </p>
          <div class="schedule__dojos-grid">
            {
              affiliatedDojos.map((dojo) => (
                <DojoCard
                  id={dojo.id}
                  name={dojo.name}
                  sensei={dojo.sensei}
                  category={dojo.category}
                />
              ))
            }
          </div>

          <p class="schedule__dojos-footer">
            加盟、準加盟道場は直接各団体へ問い合わせ下さい。
          </p>
        </div>
        
      </div>

      <!-- Modals -->
      {
        dojos.map((dojo) => (
          <DojoModal
            id={dojo.id}
            name={dojo.name}
            phone={dojo.phone}
            title={dojo.title}
            subtitle={dojo.subtitle}
            locations={dojo.locations}
            category={dojo.category}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>