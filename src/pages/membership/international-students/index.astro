---
import BaseLayout from "@layouts/BaseLayout.astro";

const longTerm = [
  { name: "Hashini / Sri Lanka", years: "2011-2021", rank: "四段", image: "hashini.jpg", href: "https://www.youtube.com/watch?v=UpRmPGwuNNM" },
  { name: "Erica / Sweden", years: "2025-2026", rank: "", image: "erica2.jpg", href: "https://www.facebook.com/erica.bokelius" },
  { name: "Alex / Australia", years: "2007-2013", rank: "二段", image: "alex.jpg" },
  { name: "Emmet / Ireland", years: "2009-2013", rank: "", image: "emet.jpg" },
  { name: "Daniela / Italy", years: "2016-2019", rank: "二段", image: "dani.jpg" },
  { name: "Sahan / Sri Lanka", years: "2018-2021", rank: "二段", image: "sahan.jpg", href: "https://www.youtube.com/watch?v=UpRmPGwuNNM" },
];

const shortTerm = [
  { name: "Mario / Spain", years: "2007 / 2008", image: "mario.jpg" },
  { name: "Silvia / Italy", years: "2016", image: "silvia.jpg" },
  { name: "Erica / Sweden", years: "2015 / 2016 / 2025", image: "erica.jpg" },
  { name: "Josephine / Sweden", years: "2016", image: "josefin.jpg" },
];

const IMG = "/assets/images/legacy/intern/";
---

<BaseLayout
  title="外国人空手留学生 - Karate International Students"
  description="清心会本部で空手を学んだ外国人留学生・内弟子のご紹介。空手文化ビザによる長期留学制度、宿泊施設、短期留学生の受け入れについてご案内します。"
  lang="ja"
  path="/membership/international-students/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">INTERNATIONAL</span>
        <h1 class="section-title">外国人空手留学生</h1>
      </div>

      <p class="detail-page__lead">
        [JAPAN Old style karate "Seishinkai dojo"]<br />
        清心会で空手を学ぼうとする外国人は、空手文化ビザを取得して長期間に渡り滞在して、空手を学ぶことが出来ます。<br />
        <em
          >Get a karate culture visa and stay for a long time to learn
          karate.</em
        ><br />
        以下は清心会本部で学んだ長期実習生(留学生)たちです。<br />
        <em
          >The following are long-term trainees (international students) who
          studied at Seishinkai Headquarters.</em
        >
      </p>

      <p class="detail-page__note">
        清心流空手を学ぶ人のための宿泊施設があります。<em
          >Accommodation available for foreign trainees of Seishinryu
          Karate.</em
        ><br />
        <a href="https://youtu.be/Q6q0g7h7f0A" target="_blank" rel="noopener"
          >宿泊施設の紹介動画(YouTube)を見る</a
        >
      </p>

      <h2 class="detail-page__heading">
        ◆外国人特別長期留学生(指導者養成コース)・内弟子<br />
        <small>Long-term foreign student, leader training course</small>
      </h2>

      <div class="detail-gallery">
        {
          longTerm.map((student) =>
            student.href ? (
              <figure>
                <a href={student.href} target="_blank" rel="noopener">
                  <img src={`${IMG}${student.image}`} alt={student.name} loading="lazy" />
                </a>
                <figcaption>
                  {student.name}
                  <br />
                  {student.years}
                  {student.rank && ` ${student.rank}`}
                </figcaption>
              </figure>
            ) : (
              <figure>
                <img src={`${IMG}${student.image}`} alt={student.name} loading="lazy" />
                <figcaption>
                  {student.name}
                  <br />
                  {student.years}
                  {student.rank && ` ${student.rank}`}
                </figcaption>
              </figure>
            )
          )
        }
      </div>

      <h2 class="detail-page__heading">
        ◆外国人短期留学生(修了者)<br />
        <small>Foreign short-term students (Graduates)</small>
      </h2>

      <div class="detail-gallery">
        {
          shortTerm.map((student) => (
            <figure>
              <img src={`${IMG}${student.image}`} alt={student.name} loading="lazy" />
              <figcaption>
                {student.name}
                <br />
                {student.years}
              </figcaption>
            </figure>
          ))
        }
      </div>

      <h2 class="detail-page__heading">稽古の様子</h2>
      <div class="detail-gallery">
        <figure>
          <a
            href="https://www.youtube.com/watch?v=UpRmPGwuNNM"
            target="_blank"
            rel="noopener"
          >
            <img src={`${IMG}DSC_4462.jpg`} alt="留学生の稽古風景" loading="lazy" />
          </a>
        </figure>
        <figure>
          <img src={`${IMG}DSC_4138.jpg`} alt="留学生の稽古風景" loading="lazy" />
        </figure>
        <figure>
          <img src={`${IMG}DSC_3105.jpg`} alt="留学生の稽古風景" loading="lazy" />
        </figure>
      </div>

      <p class="detail-page__note">
        国内在住の外国人の方は、日本人と同じ形での入会となります。<br />
        <em
          >Foreigners residing in Japan will be charged the same enrollment
          and fees as Japanese.</em
        ><br />
        <a href="/assets/pdf/kis.pdf" target="_blank"
          >About karate study abroad expenses(PDF)</a
        >
      </p>

      <h2 class="detail-page__heading">Inquiry by message</h2>
      <div class="detail-gallery">
        <figure>
          <a
            href="https://www.facebook.com/katsumi.okubo.9"
            target="_blank"
            rel="noopener"
          >
            <img
              src="/assets/images/legacy/images/okubos.jpg"
              alt="Soke Okubo"
              loading="lazy"
            />
          </a>
          <figcaption>Soke Okubo</figcaption>
        </figure>
        <figure>
          <a
            href="https://www.facebook.com/nobutaka.maekawa"
            target="_blank"
            rel="noopener"
          >
            <img
              src="/assets/images/legacy/images/maekawa.jpg"
              alt="Master Maekawa"
              loading="lazy"
            />
          </a>
          <figcaption>Master Maekawa</figcaption>
        </figure>
      </div>

      <p class="detail-page__back">
        <a href="/membership/">← 入会の御案内へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
