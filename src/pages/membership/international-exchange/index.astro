---
import BaseLayout from "@layouts/BaseLayout.astro";

const visits = [
  { year: "2026", place: "オーストラリア", image: "/assets/images/legacy/news/2026/dallen202607.jpg" },
  { year: "2026", place: "スウェーデン", image: "/assets/images/legacy/news/2026/sweden.jpg" },
  { year: "2025", place: "ノルウエー", image: "/assets/images/legacy/news/2026/nolway.jpg" },
  { year: "2025", place: "スウェーデン", image: "/assets/images/legacy/news/2025/erica.jpg" },
  { year: "2025", place: "スリランカ", image: "/assets/images/legacy/news/2025/kkpp.jpg" },
  { year: "2024", place: "アルゼンチン", image: "/assets/images/legacy/news/2024gon.jpg" },
  { year: "2024", place: "ロシア", image: "/assets/images/legacy/news/2024ro.jpg" },
  { year: "2023", place: "スウェーデンへ訪問", image: "/assets/images/legacy/news/2023sweden.jpg" },
  { year: "2024", place: "スリランカ", image: "/assets/images/legacy/news/2024kk.jpg" },
  { year: "2019", place: "イタリア/アルゼンチン", image: "/assets/images/legacy/news/2019b.jpg" },
  { year: "2019", place: "イタリア/アルゼンチン", image: "/assets/images/legacy/news/2019a.jpg" },
  { year: "2018", place: "イタリア/パキスタン/アルゼンチン", image: "/assets/images/legacy/intern/2018.jpg", href: "https://red.ap.teacup.com/applet/karate-news/201809/archive" },
  { year: "2018", place: "インド", image: "/assets/images/legacy/intern/2018b.jpg", href: "https://red.ap.teacup.com/applet/karate-news/201805/archive" },
  { year: "2017", place: "オーストラリア", image: "/assets/images/legacy/intern/2017.1.jpg", href: "https://www.youtube.com/watch?v=xYKuv0V5Y7o" },
  { year: "2017", place: "イタリア/パキスタン/フランス", image: "/assets/images/legacy/intern/2017b.jpg", href: "https://www.youtube.com/watch?v=mEdD0fOIVaA" },
  { year: "2015", place: "スウェーデン", image: "/assets/images/legacy/intern/2015.jpg", href: "https://red.ap.teacup.com/karate-news/311.html" },
  { year: "2016", place: "イタリア/アルゼンチン", image: "/assets/images/legacy/intern/tamas.jpg", href: "https://www.youtube.com/watch?v=JnYL0ukfJcU" },
  { year: "2013", place: "スウェーデン", image: "/assets/images/legacy/intern/Image9.jpg", href: "https://www.youtube.com/watch?v=UR9dPqzvwEQ" },
  { year: "2014", place: "イタリア/アルゼンチン/エジプト", image: "/assets/images/legacy/intern/P9020012.jpg", href: "https://red.ap.teacup.com/karate-news/180.html" },
];
---

<BaseLayout
  title="空手古武道国際交流 - International Karate Exchange"
  description="海外から清心会総本部道場を訪れる外国人空手指導者たちとの国際交流の記録。スウェーデン、イタリア、スリランカなど、世界各国との交流の様子をご紹介します。"
  lang="ja"
  path="/membership/international-exchange/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">INTERNATIONAL</span>
        <h1 class="section-title">空手古武道国際交流</h1>
      </div>

      <p class="detail-page__lead">
        [海外から外国人師範・空手指導者が訪れる清心会空手]<br />
        清心会総本部道場には毎年、海外から外国人空手指導者たちが訪れます。<br />
        その多くは競技スポーツでない伝統文化としての空手を求めて北海道の清心会へ訪れ、その後、沖縄へと向かいます(その逆に沖縄によってから北海道札幌へ来る場合もあります)。<br />
        外国人師範の多くは競技空手を経て、修行し足りないものを補いに更に空手の源流を求めて古流空手へたどり着きます。
      </p>

      <h2 class="detail-page__heading">空手古武道国際交流</h2>
      <div class="detail-gallery">
        {
          visits.map((v) =>
            v.href ? (
              <figure>
                <a href={v.href} target="_blank" rel="noopener">
                  <img src={v.image} alt={`${v.year} ${v.place}`} loading="lazy" />
                </a>
                <figcaption>{v.year} {v.place}</figcaption>
              </figure>
            ) : (
              <figure>
                <img src={v.image} alt={`${v.year} ${v.place}`} loading="lazy" />
                <figcaption>{v.year} {v.place}</figcaption>
              </figure>
            )
          )
        }
      </div>

      <p class="detail-page__note">
        来訪国は、スウェーデン、イタリア、パキスタン、エジプト、オーストラリア、フランス、アルゼンチン、スリランカ、インド、クウェート、アイルランド、アメリカなど。
      </p>

      <h2 class="detail-page__heading">簡易短期宿泊施設</h2>
      <div class="detail-page__img-text-pair--col">
        <div class="detail-media--big">
          <a target="_blank" href="https://www.youtube.com/watch?v=Q6q0g7h7f0A">
            <figure>
              <img
                src="/assets/images/youtube/img_accommodation-thumb.jpg"
                alt="簡易短期宿泊施設"
                loading="lazy"
              />
            </figure>
          </a>
        </div>

        <p>
          海外からの訪問者向けに、短期滞在用の宿泊施設をご用意しております。
        </p>
      </div>

      <h2 class="detail-page__heading">稽古の様子</h2>
      <div class="detail-gallery">
        <figure>
          <img
            src="/assets/images/legacy/intern/P4030057.jpg"
            alt="タマス先生(WKF10段)"
            loading="lazy"
          />
          <figcaption>タマス先生(WKF10段)</figcaption>
        </figure>
        <figure>
          <img
            src="/assets/images/legacy/intern/scaba.jpg"
            alt="サカバ先生(沖縄小林流10段)"
            loading="lazy"
          />
          <figcaption>サカバ先生(沖縄小林流10段)</figcaption>
        </figure>
        <figure>
          <img
            src="/assets/images/legacy/intern/DSC_0182.jpg"
            alt="ダレン先生(喜屋武派少林流9段)"
            loading="lazy"
          />
          <figcaption>ダレン先生(喜屋武派少林流9段)</figcaption>
        </figure>
      </div>

      <h2 class="detail-page__heading">Inquiry by message</h2>
      <p class="detail-page__note">
        Please use email or messenger. Other people are Japanese only.
      </p>
      <div class="detail-gallery">
        <figure>
          <a
            href="https://www.facebook.com/katsumi.okubo.9"
            target="_blank"
            rel="noopener"
          >
            <img
              src="/assets/images/legacy/images/okubos.jpg"
              alt="Soke Okubo"
              loading="lazy"
            />
          </a>
          <figcaption>Soke Okubo</figcaption>
        </figure>
        <figure>
          <a
            href="https://www.facebook.com/nobutaka.maekawa"
            target="_blank"
            rel="noopener"
          >
            <img
              src="/assets/images/legacy/images/maekawa.jpg"
              alt="Master Maekawa"
              loading="lazy"
            />
          </a>
          <figcaption>Master Maekawa</figcaption>
        </figure>
      </div>

      <p class="detail-page__back">
        <a href="/membership/">← 入会の御案内へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
