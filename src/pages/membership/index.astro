---
import BaseLayout from "@layouts/BaseLayout.astro";
import Button from "@components/buttons/Button.astro";
import ArrowRight from "@components/buttons/ArrowRight.astro";
---

<BaseLayout title="Membership" lang="ja" path="/membership/">
  <section class="membership" id="membership">
    <div class="membership__container">
      <h1>Page Title</h1>
      <p>初心者から経験者まで、年齢・性別を問わず誰でも学べる空手教室</p>

      <h2>Who's it for?</h2>

      <div class="membership__audience">
        <div class="membership__audience-card">
          <div class="membership__audience-icon">🧒</div>
          <h3 class="membership__audience-title">少年部</h3>
          <p class="membership__audience-text">
            礼儀・挨拶・作法を学び、心と身体を育てる
          </p>
        </div>

        <div class="membership__audience-card">
          <div class="membership__audience-icon">👩</div>
          <h3 class="membership__audience-title">女性・一般</h3>
          <p class="membership__audience-text">
            シェイプアップ・健康促進・護身
          </p>
        </div>

        <div class="membership__audience-card">
          <div class="membership__audience-icon">👴</div>
          <h3 class="membership__audience-title">中高年</h3>
          <p class="membership__audience-text">無理なく体力向上・健康維持</p>
        </div>
      </div>

      <h2>features</h2>

      <div class="membership__features">
        <div class="membership__feature-item">
          <div class="membership__feature-icon">🎯</div>
          <p class="membership__feature-text">「体育・健康・護身」を重視</p>
        </div>

        <div class="membership__feature-item">
          <div class="membership__feature-icon">🤋</div>
          <p class="membership__feature-text">
            試合中心ではなく 基本・型・約束組手が中心
          </p>
        </div>

        <div class="membership__feature-item">
          <div class="membership__feature-icon">👥</div>
          <p class="membership__feature-text">
            年齢・性別問わず誰でも取り組める
          </p>
        </div>

        <div class="membership__feature-item">
          <div class="membership__feature-icon">🌏</div>
          <p class="membership__feature-text">海外との国際交流あり</p>
        </div>

        <div class="membership__feature-item">
          <div class="membership__feature-icon">👨‍👩‍👧</div>
          <p class="membership__feature-text">親子での参加が多い</p>
        </div>

        <div class="membership__feature-item">
          <div class="membership__feature-icon">💻</div>
          <p class="membership__feature-text">オンラインクラス対応</p>
        </div>
      </div>

      <h2>コミュニティの魅力</h2>

      <div class="membership__community">
        <p>社会人会員が多く、異業種交流ができる</p>
        <p>空手を通じて人とのつながりが広がる</p>
        <p>指導者の多くが親子で継続しているメンバー</p>
      </div>

      <h2>通いやすいシステム</h2>

      <div class="membership__training-access">
        <p>札幌・近郊 約80支部に自由参加</p>
        <p>何度でも練習参加可能</p>
        <p>ビジター・チケット制度あり</p>
        <p class="membership__training-note">※カルチャースクール等は対象外</p>
      </div>

      <h2>入会費用</h2>

      <div class="membership__fees">
        <div class="membership__fees-card">
          <div class="membership__fees-section">
            <h3 class="membership__fees-title">入会金</h3>
            <p class="membership__fees-amount">7,000円</p>
            <p class="membership__fees-detail">
              家族割引あり（2人目 3,500円 / 3人目 1,750円）
            </p>
          </div>

          <div class="membership__fees-section">
            <h3 class="membership__fees-title">月会費</h3>
            <p class="membership__fees-detail">子ども：5,300円</p>
            <p class="membership__fees-detail">
              学生・女性・一般：5,800～6,800円
            </p>
            <p class="membership__fees-detail">3歳未満：無料</p>
          </div>

          <p class="membership__fees-note">
            ※冬季は暖房費あり（1,100～3,000円）
          </p>
        </div>

        <div class="membership__fees-card">
          <div class="membership__fees-section">
            <h3 class="membership__fees-title">その他</h3>
            <p class="membership__fees-detail">
              年会費：4,800～6,800円（保険込）
            </p>
            <p class="membership__fees-detail">道着：10,500～22,000円</p>
            <p class="membership__fees-detail">サポーター：6,250～8,250円</p>
          </div>
        </div>
      </div>

      <h2>無料体験について</h2>

      <div class="membership__trial">
        <p>直轄教室は無料体験OK</p>
        <p>初心者歓迎</p>
        <p>動きやすい服装で参加可能</p>
      </div>

        <a href="#contact">
          <button class='button-inverse'>
            <span class="button__label">無料体験</span>
            <ArrowRight />
          </button>
        </a>

      <div class="accordion">
        <div class="accordion__item">
          <button class="accordion__button" data-accordion-trigger="notes">
            <span>Notes / Important Info（注意事項）</span>
            <svg
              class="accordion__icon"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="accordion__panel" data-accordion-panel="notes">
            <div class="accordion__content">
              <ul class="membership__notes-list">
                <li>月会費は口座引落</li>
                <li>NPOのため消費税なし</li>
                <li>支部ごとに多少異なる場合あり</li>
                <li>稽古の有無に関係なく会費は発生</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
    <section class="top-contact" id="contact">

    <div class="layout__container">
      <div class="top-contact__contact-header">
        <span>CONTACT</span>
        <h2>体験申込・お問い合わせ</h2>
        <p>清心会空手体験申込はこちらからご連絡ください</p>
      </div>

      <div class="top-contact__contact-grid">

        <!-- Phone -->
        <div class="top-contact__contact-card highlight">
          <div class="top-contact__icon">☎</div>
          <h3>お電話</h3>
          <p class="top-contact__big">011-300-0048</p>
          <small>月・木 13:00〜16:00 / 火・木・金 13:00〜15:00</small>
        </div>

        <!-- Email -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">✉</div>
          <h3>メール</h3>
          <p class="top-contact__email">Karate@seishinkan.ne.jp</p>
          <small>24時間受付</small>
        </div>

        <!-- Fax -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">📠</div>
          <h3>FAX</h3>
          <p>011-300-0094</p>
        </div>

        <!-- QR -->
        <div class="top-contact__contact-card top-contact__qr-card">
          <img src="/seishinkai/assets/images/img_qr_volunteer.jpg" alt="お問い合わせQRコード">
          <p>スマホから簡単お問い合わせ</p>
        </div>

      </div>

      <div class="top-contact__contact-info">
        <div>
          <h4>受付時間</h4>
          <p>月〜金 13:00〜15:00</p>
        </div>

        <div>
          <h4>所在地</h4>
          <p>札幌市白石区栄通2丁目1-27（東北通沿）</p>
        </div>
      </div>

      <div class="top-contact__notice-box">
        <strong>ご注意</strong>
        <p>
          事務局は交代制のため、時間内でも電話対応できない場合があります。
          その際はメールにてお問い合わせください。
        </p>
      </div>
    </div>
  </section>
</BaseLayout>