---
import BaseLayout from "@layouts/BaseLayout.astro";
import BranchTable from "@components/BranchTable.astro";

const entries = [
  {
    no: 1,
    marker: "□",
    name: "住吉塾西町教室",
    address: "西区西町北10丁目　手稲東児童会館",
    schedule: ["火曜19:00"],
  },
  {
    no: 2,
    marker: "□",
    name: "住吉塾宮の沢教室",
    address: "西区西町南21丁目　手稲記念館",
    schedule: ["土曜13:00"],
  },
  {
    no: 3,
    marker: "□",
    name: "住吉塾発寒教室",
    address: "西区宮の沢1条5丁目　宮の沢児童会館",
    schedule: ["金曜19:00"],
  },
  {
    no: 4,
    marker: "□",
    name: "住吉塾八軒教室",
    address: "西区八軒3条東4丁目　八軒東会館",
    schedule: ["土曜17:00"],
  },
  {
    no: 5,
    marker: "□",
    name: "住吉塾新発寒道場",
    address: "手稲区新発寒6条4丁目　新発寒児童会館",
    schedule: ["水曜19:00"],
  },
  {
    no: 6,
    marker: "□",
    name: "住吉塾手稲教室",
    address: "手稲区手稲本町３条１丁目　手稲コミニティセンター",
    schedule: ["木曜19:00"],
  },
  {
    no: 7,
    marker: "□",
    name: "住吉塾星置明日風教室",
    address: "手稲区星置2条3丁目 星置地区センター",
    schedule: ["月曜19:00"],
  },
];
---

<BaseLayout
  title="手稲区・西区の空手教室"
  description="札幌市手稲区・西区の清心会空手道場・教室一覧。住吉塾の西町・宮の沢・発寒・八軒・新発寒・手稲・星置明日風の各教室の稽古日をご案内します。"
  lang="ja"
  path="/dojo/teine/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <h1 class="section-title">
          手稲区空手道場・教室と西区空手道場・教室の一覧
        </h1>
      </div>
      <div class="detail-page__lead">
        <p>西区、手稲区の空手教室は、自主管理道場となっております。</p>
      </div>
      <p class="detail-page__contact">□住吉塾直通=090-7517-3285</p>

      <BranchTable entries={entries} />

      <ul class="detail-legend">
        <li>
          <span class="detail-legend__marker">★</span>本部直轄教室=お問い合わせは本部事務局へ
        </li>
        <li>
          <span class="detail-legend__marker">●</span>講師派遣教室=お問い合わせは主催文化教室・スポーツクラブへ
        </li>
        <li>
          <span class="detail-legend__marker">□</span>自主管理道場=事務局011-300-0048(平日13:00-16:00)
          又は直接、管理担当者へ
        </li>
      </ul>

      <h2 class="detail-page__heading">住吉塾 各教室の紹介ページ</h2>
      <ul class="detail-links">
        <li>
          <a
            href="https://sumiyoshijuku.org/class/nishimachi/"
            target="_blank"
            rel="noopener">住吉塾西町教室</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/miyanosawa/"
            target="_blank"
            rel="noopener">住吉塾宮の沢教室</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/hassamu/"
            target="_blank"
            rel="noopener">住吉塾発寒教室</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/hachiken/"
            target="_blank"
            rel="noopener">住吉塾八軒教室</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/shinhassamu/"
            target="_blank"
            rel="noopener">住吉塾新発寒道場</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/teine/"
            target="_blank"
            rel="noopener">住吉塾手稲教室</a
          >
        </li>
        <li>
          <a
            href="https://sumiyoshijuku.org/class/hoshioki/"
            target="_blank"
            rel="noopener">住吉塾星置明日風教室</a
          >
        </li>
      </ul>

      <p class="detail-page__back">
        <a href="/dojo/">← 空手道場・教室の一覧へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
