---
import BaseLayout from "@layouts/BaseLayout.astro";
import BranchTable from "@components/BranchTable.astro";

const entries = [
  {
    no: 1,
    marker: "★",
    name: "総本部/清心館栄通",
    address: "白石区栄通2丁目(東北通沿)",
    schedule: ["月〜日"],
  },
  {
    no: 2,
    marker: "★",
    name: "月寒支部",
    address: "月寒西1条6丁目3-21 月寒児童会館",
    schedule: ["土曜18:25"],
  },
  {
    no: 3,
    marker: "★",
    name: "豊平支部",
    address: "豊平区豊平6条7丁目1-12豊平児童会館",
    schedule: ["土曜18:20"],
  },
  {
    no: 4,
    marker: "★",
    name: "豊平公園支部",
    address: "豊平区豊平8条11丁目 豊平若者活動センター",
    schedule: ["金曜16:00"],
  },
  {
    no: 5,
    marker: "★",
    name: "美園支部",
    address: "豊平区美園6条7丁目コープ美園サークル室",
    schedule: ["日曜13:30"],
  },
  {
    no: 6,
    marker: "★",
    name: "福住支部",
    address: "福住1条1丁目5-5 福住児童会館",
    schedule: ["水曜18:30"],
  },
  {
    no: 7,
    marker: "★",
    name: "西岡支部",
    address: "南区澄川6条4丁目 コープ西岡2F",
    schedule: ["土曜13:00"],
  },
  {
    no: 8,
    marker: "★",
    name: "澄川支部",
    address: "豊平区平岸1条22丁目 ビックハウスエクストラ店2F",
    schedule: ["金曜18:30(R3.4より)"],
  },
];
---

<BaseLayout
  title="豊平区の空手教室"
  description="札幌市豊平区の清心会空手道場・教室一覧。月寒・豊平・美園・福住・西岡・澄川など各支部の稽古日をご案内します。"
  lang="ja"
  path="/dojo/toyohira/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <h1 class="section-title">豊平区空手道場・教室の一覧</h1>
      </div>
      <p class="detail-page__contact">
        お問い合わせは　TEL.011-300-0048(平日13:00-16:00)※土日は受付はありません
      </p>

      <BranchTable entries={entries} />

      <ul class="detail-legend">
        <li>
          <span class="detail-legend__marker">★</span>本部直轄教室=お問い合わせは本部事務局へ
        </li>
        <li>
          <span class="detail-legend__marker">●</span>会場都合、指導員移動時間等(夏冬)で掲載の開始時刻と若干変動する場合があります
        </li>
      </ul>

      <div class="detail-media">
        <img
          src="/assets/images/legacy/photo/Image2.jpg"
          alt="豊平区の清心会空手 稽古風景"
          width="570"
          height="340"
          loading="lazy"
        />
      </div>

      <p class="detail-page__back">
        <a href="/dojo/">← 空手道場・教室の一覧へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
