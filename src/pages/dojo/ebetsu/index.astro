---
import BaseLayout from "@layouts/BaseLayout.astro";
import BranchTable from "@components/BranchTable.astro";

const entries = [
  {
    no: 1,
    marker: "#",
    name: "清心館大麻道場",
    sub: "(江別地区本部道場)",
    address: "江別市大麻沢町6-9 パークヒルズ1F 清心館(二番通沿)",
    schedule: [
      "月曜16:00",
      "木曜18:30",
      "金曜16:00",
      "金曜18:45(予約制)",
      "土曜10:00",
    ],
  },
  {
    no: 2,
    marker: "#",
    name: "野幌空手クラブ",
    address: "江別市野幌屯田町23-6 杜の台記念会館",
    schedule: ["水曜18:30"],
  },
  {
    no: 3,
    marker: "#",
    name: "江別空手クラブ",
    address: "江別市3条5丁目11-1 江別中央公民館",
    schedule: ["金曜18:30"],
  },
  {
    no: 4,
    marker: "●",
    name: "イオン江別空手クラブ",
    address: "江別市幸町34 イオン江別3F",
    schedule: ["日曜10:00", "日曜13:00(準備中)"],
  },
  {
    no: 5,
    marker: "#",
    name: "岩見沢空手クラブ",
    address: "岩見沢市4条西1丁目 岩見沢生涯学習センター",
    schedule: ["月曜18:30"],
  },
  {
    no: 6,
    marker: "#",
    name: "石狩花川空手クラブ",
    address: "石狩市花川南6-5 花川南コミニティセンター",
    schedule: ["火曜16:30"],
  },
  {
    no: 7,
    marker: "#",
    name: "石狩緑苑台空手クラブ",
    address: "石狩市緑苑台東2条1丁目 緑苑台グリーン会館",
    schedule: ["土曜15:30"],
  },
  {
    no: 8,
    marker: "★",
    name: "石狩花川北空手クラブ",
    address: "※R4.11より緑苑台支部と統合となります",
    schedule: [],
  },
];
---

<BaseLayout
  title="江別・岩見沢・石狩の空手教室"
  description="江別市・岩見沢市・石狩市の清心会空手道場・教室一覧。大麻道場をはじめ各支部の稽古日をご案内します。"
  lang="ja"
  path="/dojo/ebetsu/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <h1 class="section-title">
          江別市空手道場・石狩市空手教室・岩見沢市空手教室の一覧
        </h1>
      </div>
      <p class="detail-page__contact">
        お問い合わせは　TEL.011-300-0048(平日13:00-16:00)
      </p>

      <BranchTable entries={entries} />

      <ul class="detail-legend">
        <li>
          <span class="detail-legend__marker">★</span>本部直轄教室=お問い合わせは本部事務局へ
        </li>
        <li>
          <span class="detail-legend__marker">●</span>講師派遣教室=お問い合わせは主催文化教室・スポーツクラブへ
        </li>
        <li>
          <span class="detail-legend__marker">□</span>自主管理道場=事務局又は直接、管理担当者へ
        </li>
      </ul>

      <p class="detail-page__note">
        関連リンク：<a
          href="https://www.ebe-2.net/楽しみながらできる！キッズ空手倶楽部/"
          target="_blank"
          rel="noopener">イオン江別空手クラブ(キッズ空手倶楽部)</a
        >
      </p>

      <div class="detail-media">
        <img
          src="/images/legacy/photo/Image2.jpg"
          alt="清心会空手の稽古風景"
          width="570"
          height="340"
          loading="lazy"
        />
      </div>

      <p class="detail-page__back">
        <a href="/dojo/">← 空手道場・教室の一覧へ戻る</a>
      </p>
    </div>
  </section>
</BaseLayout>
