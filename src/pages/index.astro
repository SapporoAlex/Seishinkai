---
import Button from "@components/buttons/Button.astro";
import ArrowRight from "@components/buttons/ArrowRight.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import data from 'src/data/cards-who.json';
const cards = data.cards;
---

<BaseLayout title="Welcome" lang="ja" path="/">
  <section class="fv" id="fv">
    <div class="swiper-container">
      <div class="swiper-wrapper">
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_01.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_02.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_03.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_04.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_05.jpg" alt="" />
              </div>
            </div>
          </div>
      <div class="fv__overlay"></div>
      <div class="fv__text">
        <div class="fv-eyebrow">SEISHINKAI KARATE</div>
        <h1 class="fv__title">心と身体を<br>鍛える空手</h1>
        <p class="fv__copy">3歳から83歳まで。礼儀・健康・護身を柱に、<br>50年以上続く清心流空手道場へようこそ。</p>
        <a href="#contact">
        <div class="fv-btn-primary">無料体験を申込む</div>
        </a>
      </div>
    </div>
  </section>

  <section class="cards-who" id="cards-who">
      <div class="cards-who__container">
        <img class="cards-who__top-img" src="/seishinkai/assets/images/logo.svg" alt="">
        <div class="section__title-area">
          <span class="section-label">ABOUT</span>
          <div class="section-title">清心会</div>
        </div>
        <p class="text">清心会は、競技中心ではなく心身の成長と健康を大切にする伝統空手道場です。3歳から83歳まで幅広い年齢層が参加し、50年以上にわたり札幌を中心に活動しています。子どもには発育を促す体育として、大人やシニアには健康維持として、女性には護身術として、それぞれに合わせた指導を行っています。また、不登校生徒向けクラスや外国人の受け入れも行い、誰もが安心して学べる環境を提供しています。</p>
        <a href="/about/"><div class="fv-btn-primary">歴史を見る</div></a>
      </div>
      <div class="cards-who__container">

        <div class="section__title-area">
          <span class="section-label">CLASSES</span>
          <div class="section-title">稽古内容</div>
        </div>
        <div class="cards-who__card-box">
          <div class="cards-who__card">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/seishinkai/assets/images/icon_for-kids.png" alt=""><h3 class="cards-who__card-title">子どもの成長をサポート</h3></div>
              <div class="cards-who__card-bottom"><p class="text">発育期に合わせた運動で、体力・集中力・礼儀を育てます。</p></div>
          </div>
          <div class="cards-who__card">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/seishinkai/assets/images/icon_for-health.png" alt=""><h3 class="cards-who__card-title">健康・体力づくり</h3></div>
              <div class="cards-who__card-bottom"><p class="text">シニアや初心者でも安心。無理なく続けられる全身運動と呼吸法。</p></div>
          </div>
          <div class="cards-who__card">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/seishinkai/assets/images/icon_for-everyone.png" alt=""><h3 class="cards-who__card-title">誰でも参加できる環境</h3></div>
              <div class="cards-who__card-bottom"><p class="text">不登校支援クラス・外国人歓迎・保護者負担なしで安心して通えます。</p></div>
          </div>
          <div class="cards-who__card">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/seishinkai/assets/images/icon_for-resilience.png" alt=""><h3 class="cards-who__card-title">護身・メンタル強化</h3></div>
              <div class="cards-who__card-bottom"><p class="text">女性や学生向けに、実践的な護身術と折れない心を育てます。</p></div>
          </div>
        </div>
      </div>
  </section>

  <section class="top-section">
    <div class="top-section__container -reverse">
      <img class="top-section__kv-img" src="/seishinkai/assets/images/bg_schedule.jpg" alt="">
      <div class="section__title-area">
        <span class="section-label">SCHEDULE</span>
        <div class="section-title">スケジュール</div>
        <a href="/schedule/"><div class="fv-btn-primary">スケジュールを見る</div></a>
        <p class="text">札幌市内をはじめ北海道各地の清心会空手道場・教室の稽古予定を掲載しています。練習日程や行事予定、休講情報などを随時ご確認いただけます。</p>
      </div>

    </div>
        <div class="top-section__container">
      <img class="top-section__kv-img" src="/seishinkai/assets/images/bg_dojos.jpg" alt="">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <div class="section-title">道場一覧</div>
        <a href="/dojo/"><div class="fv-btn-primary">道場一覧を見る</div></a>
        <p class="text">清心会空手道連盟の公認・加盟道場をご案内しています。札幌市内をはじめ北海道各地、海外の道場情報や教室一覧をご覧いただけます。</p>
      </div>

    </div>
        <div class="top-section__container -reverse">
      <img class="top-section__kv-img" src="/seishinkai/assets/images/bg_instructors.jpg" alt="">
      <div class="section__title-area">
        <span class="section-label">INSTRUCTORS</span>
        <div class="section-title">インストラクター</div>
        <a href="/instructors/"><div class="fv-btn-primary">インストラクター一覧</div></a>
        <p class="text">清心会の師範・指導員をご紹介しています。各道場を担当する指導者のプロフィールや担当地区をご覧いただけます。</p>
      </div>

    </div>
        <div class="top-section__container">
      <img class="top-section__kv-img" src="/seishinkai/assets/images/bg_membership.jpg" alt="">
      <div class="section__title-area">
        <span class="section-label">MEMBERSHIP</span>
        <div class="section-title">入会</div>
        <a href="/membership/"><div class="fv-btn-primary">詳しく見る</div></a>
        <p class="text">子どもから大人まで、年齢や経験を問わず学べる清心会空手。入会方法や費用、無料体験についてご確認いただけます。</p>
      </div>

    </div>
  </section>

  <section class="top-contact" id="contact">

    <div class="layout__container">
      <div class="section__title-area">
        <span class="section-label">CONTACT</span>
        <div class="section-title u-color-white">体験申込・お問い合わせ</div>
        <p class="text u-color-text-lightest">清心会空手体験申込はこちらからご連絡ください</p>
      </div>

      <div class="top-contact__contact-grid">

        <!-- Phone -->
        <div class="top-contact__contact-card highlight">
          <div class="top-contact__icon">☎</div>
          <h3>お電話</h3>
          <p class="top-contact__big">011-300-0048</p>
          <small>月・木 13:00〜16:00 / 火・木・金 13:00〜15:00</small>
        </div>

        <!-- Email -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">✉</div>
          <h3>メール</h3>
          <p class="top-contact__email">Karate@seishinkan.ne.jp</p>
          <small>24時間受付</small>
        </div>

        <!-- Fax -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">📠</div>
          <h3>FAX</h3>
          <p>011-300-0094</p>
        </div>

        <!-- QR -->
        <div class="top-contact__contact-card top-contact__qr-card">
          <img src="/seishinkai/assets/images/img_qr_volunteer.jpg" alt="お問い合わせQRコード">
          <p>スマホから簡単お問い合わせ</p>
        </div>

      </div>

      <div class="top-contact__contact-info">
        <div>
          <h4>受付時間</h4>
          <p>月〜金 13:00〜15:00</p>
        </div>

        <div>
          <h4>所在地</h4>
          <p>札幌市白石区栄通2丁目1-27（東北通沿）</p>
        </div>
      </div>

      <div class="top-contact__notice-box">
        <strong>ご注意</strong>
        <p>
          事務局は交代制のため、時間内でも電話対応できない場合があります。
          その際はメールにてお問い合わせください。
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
