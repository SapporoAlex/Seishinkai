---
import BaseLayout from "@layouts/BaseLayout.astro";
import ProfileCard from "@components/ProfileCard.astro";
import sections from "@data/instructors.json";
import beltLevels from "@data/belt-levels.json";
---

<BaseLayout
  title="師範・指導員紹介"
  description="清心会空手の師範・支部長・指導員のご紹介。各道場を指導する指導陣の一覧です。"
  lang="ja"
  path="/instructors/"
>
  <section class="instructors">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">INSTRUCTORS</span>
        <h1 class="section-title">師範・支部長</h1>
      </div>

      {
        sections.map((section) => (
          <div class="instructors__category">
            <h2 class="instructors__category-title">
              {section.title}
              {section.subtitle && (
                <span class="instructors__category-subtitle">
                  {section.subtitle}
                </span>
              )}
            </h2>

            {section.groups.map((group) => (
              <div class="instructors__group">
                {group.title && (
                  <h3 class="instructors__subsection-title">{group.title}</h3>
                )}
                {group.note && <p class="instructors__note">{group.note}</p>}

                <div class="instructors__grid">
                  {group.members.map((member) => (
                    <ProfileCard
                      id={member.id}
                      image={member.image}
                      name={member.name}
                      role={member.role}
                      position={member.position}
                      date={member.date}
                      prefecture={member.prefecture}
                      profession={member.profession}
                      details={member.details}
                      tags={member.tags}
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))
      }

      <div class="instructors__belt-levels">
        <h2 class="instructors__category-title">
          登録段位保持者 (※{beltLevels.lastUpdated}現在)
        </h2>

        <table class="instructors__dan-table">
          <tbody>
            <tr>
              {beltLevels.danRanks.map((rank) => <th>{rank.rank}</th>)}
            </tr>
            <tr>
              {beltLevels.danRanks.map((rank) => <td>{rank.count}名</td>)}
            </tr>
          </tbody>
        </table>

        <h3 class="instructors__subsection-title">準加盟・提携道場</h3>
        <table class="table">
          <tbody>
            {
              beltLevels.associateDojos.map((dojo) => (
                <tr>
                  <th>{dojo.name}</th>
                  <td>
                    {dojo.location} / {dojo.dojo}
                  </td>
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
