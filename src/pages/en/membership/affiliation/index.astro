---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactSection from "@components/ContactSection.astro";
---


<BaseLayout
  title="Membership & Seminar Information"
  description="Learn about joining the Seishinkai Karate Federation, including information for school clubs, community groups, cultural schools, and seminars for companies and educational institutions."
  lang="en"
  path="/en/membership/affiliation/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">AFFILIATION</span>
        <h1 class="section-title">Seminars & Affilliating with Seishinkai</h1>
      </div>

      <p class="detail-page__lead">
        If you are interested in establishing a new karate program through a school club,
        community group, cultural school, or other organization, please feel free to contact us.
        In addition to our regular dojo classes, we also provide seminars for companies,
        schools, and community organizations upon request.
      </p>

      <h2 class="detail-page__heading">
        Karate, Iaido & Kobujutsu Experience for International Visitors
      </h2>

      <p class="detail-page__lead">
        We offer hands-on experience seminars for tourists visiting Japan and students attending
        Japanese language schools.<br>
        Visitors can also explore our Karate Reference Room, featuring a collection of historical
        materials including pre-war karate books, martial arts texts from the Meiji era,
        armor dating back to around the 1600s, and other rare historical documents.<br>
        Experience sessions are available in Karate, Iaido, and Kobujutsu (traditional martial arts).
        Instruction is available in either English or Japanese.
      </p>

