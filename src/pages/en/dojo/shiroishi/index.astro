---

<BaseLayout
  title="Karate Classes in Shiroishi Ward"
  description="A directory of Seishinkai Karate dojos and classes in Shiroishi Ward, Sapporo, including the General Headquarters Dojo and the training schedules of each branch in the ward."
  lang="en"
  path="/en/dojo/shiroishi/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <h1 class="section-title">Karate Dojos & Classes in Shiroishi Ward, Sapporo</h1>
      </div>
      <p class="detail-page__contact">
        Inquiries: TEL 011-300-0048 (weekdays 1:00 PM–4:00 PM)
      </p>

      <BranchTable
        entries={entries}
        headers={["Dojo / Branch", "Address / Venue", "Training Days"]}
      />

      <ul class="detail-legend">
        <li>
          <span class="detail-legend__marker">★</span>Headquarters-run class — inquiries to the head office
        </li>
        <li>
          <span class="detail-legend__marker">●</span>Instructor-dispatch class — inquiries to the hosting cultural center / sports club
        </li>
        <li>
          <span class="detail-legend__marker">□</span>Self-managed dojo — inquiries to the office or directly to the dojo manager
        </li>
      </ul>

      <div class="detail-media">
        <a
          href="https://www.youtube.com/watch?v=yTxLbmtNGG4"
          target="_blank"
          rel="noopener"
        >
          <img
            src="/assets/images/legacy/news/Image1.jpg"
            alt="Seishinkai Karate introduction video"
            width="598"
            height="331"
            loading="lazy"
          />
        </a>
        <p class="detail-media__caption">Introduction video (YouTube)</p>
      </div>

      <p class="detail-page__back">
        <a href="/en/dojo/">← Back to the list of dojos & classes</a>
      </p>
    </div>
  </section>
</BaseLayout>
