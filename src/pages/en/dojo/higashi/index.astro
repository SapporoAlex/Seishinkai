---
import BaseLayout from "@layouts/BaseLayout.astro";
import BranchTable from "@components/BranchTable.astro";

const entries = [
  {
    no: 1,
    marker: "★",
    name: "Fushiko Karate Club",
    address: "Fushiko Memorial Hall, Fushiko 7-jo 2-chome, Higashi-ku, Sapporo",
    schedule: ["Saturday 10:00"],
  },
  {
    no: 2,
    marker: "★",
    name: "Sapponai Karate Club",
    address: "Sapponai-Moere Community Center, Higashi-Naebo 7-jo 2-chome, Higashi-ku, Sapporo",
    schedule: ["Wednesday 18:30"],
  },
  {
    no: 3,
    marker: "★",
    name: "Okadama Karate Club",
    address:
      "Okadama Takara Children's Hall, Kita 35-jo Higashi 23-chome 7-11, Higashi-ku, Sapporo (from May 2023)",
    schedule: ["Monday 18:30"],
  },
  {
    no: 4,
    marker: "★",
    name: "Sakaemachi Karate Club",
    address: "San-ai Motors Building 3F Meeting Room, Kita 42-jo Higashi 19-chome, Higashi-ku, Sapporo",
    schedule: ["Sunday 9:30"],
  },
  {
    no: 5,
    marker: "★",
    name: "Kosei Karate Club",
    address: "Shinsei Children's Hall Gymnasium, Kita 8-jo Higashi 7-chome 1-3, Higashi-ku, Sapporo",
    schedule: ["Thursday 18:25/19:35"],
  },
  {
    no: 6,
    marker: "★",
    name: "Higashi-Kaerai Karate Club",
    address: "Higashi-Kaerai Children's Hall, Higashi-Kaerai 14-jo 2-chome 1-1, Higashi-ku, Sapporo",
    schedule: ["Thursday 18:30"],
  },
  {
    no: 7,
    marker: "★",
    name: "Sapporo Higashi Karate Club",
    address: "Sakae District Center 2F, Kita 36-jo Higashi 8-chome, Higashi-ku, Sapporo",
    schedule: ["Tuesday 18:30/19:30"],
  },
];
---

<BaseLayout
  title="Karate Classes in Higashi Ward"
  description="Directory of Seishinkai Karate dojos and classes in Higashi Ward, Sapporo. Training days for the Fushiko, Sapponai, Okadama, Sakaemachi, Kosei, Higashi-Kaerai, and Sapporo Higashi clubs."
  lang="en"
  path="/en/dojo/higashi/"
>
  <section class="dojo-list">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <h1 class="section-title">Karate Dojos & Classes in Higashi Ward, Sapporo</h1>
      </div>
      <div class="detail-page__lead">
        <p>
          Due to COVID-19, city-managed facilities may be unavailable depending on the situation; in that case, training will be held at a nearby branch instead.
        </p>
      </div>
      <p class="detail-page__contact">
        Inquiries: TEL 011-300-0048 (weekdays 1:00 PM–4:00 PM)
      </p>

      <BranchTable entries={entries} headers={["Dojo / Branch", "Address / Venue", "Training Days"]} />

      <ul class="detail-legend">
        <li>
          <span class="detail-legend__marker">★</span>Headquarters-run class — inquiries to the head office
        </li>
        <li>
          <span class="detail-legend__marker">●</span>Instructor-dispatch class — inquiries to the hosting cultural center / sports club
        </li>
        <li>
          <span class="detail-legend__marker">□</span>Self-managed dojo — inquiries to the office or directly to the dojo manager
        </li>
      </ul>

      <div class="detail-media">
        <img
          src="/assets/images/legacy/photo/Image2.jpg"
          alt="Seishinkai Karate training session"
          width="570"
          height="340"
          loading="lazy"
        />
      </div>

      <p class="detail-page__back">
        <a href="/en/dojo/">← Back to Dojo List</a>
      </p>
    </div>
  </section>
</BaseLayout>
