---
import BaseLayout from "@layouts/BaseLayout.astro";
import ContactSection from "@components/ContactSection.astro";
---

<BaseLayout lang="en" path="/en/">
  <section class="fv" id="fv">
    <div class="swiper-container">
      <div class="swiper-wrapper">
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/assets/images/img_training_01.jpg" alt="Children practicing punches at a Seishinkai karate class" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/assets/images/img_training_02.jpg" alt="Shihan demonstrating a technique at the Seishinkai headquarters dojo" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/assets/images/img_training_03.jpg" alt="Young children performing kata at a gymnasium event" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/assets/images/img_training_04.jpg" alt="Black-belt students practicing high kicks with striking pads" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/assets/images/img_training_05.jpg" alt="Group training session at an overseas Seishin-ryu dojo" />
              </div>
            </div>
          </div>
      <div class="fv__overlay"></div>
      <div class="fv__text">
        <div class="fv-eyebrow">SEISHINKAI KARATE</div>
        <h1 class="fv__title">Karate that trains<br>mind and body</h1>
        <p class="fv__copy">From age 3 to 83. Welcome to Seishin-ryu Karate —<br>over 50 years of courtesy, health, and self-defense.</p>
        <a href="#contact">
        <div class="fv-btn-primary">Book a Free Trial</div>
        </a>
      </div>
    </div>
  </section>

  <section class="cards-who" id="cards-who">
      <div class="cards-who__container-intro">
        <img class="cards-who__top-img fade-up-in" src="/assets/images/logo.svg" alt="Seishinkai Karate logo">
        <div>
          <div class="section__title-area">
            <span class="section-label">ABOUT</span>
            <div class="section-title">Seishinkai</div>
            <a href="/en/about/"><div class="fv-btn-primary">Our History</div></a>
            <p class="text">Seishinkai is a traditional karate organization that values personal growth and health over competition. Students from age 3 to 83 take part, and we have been active around Sapporo for more than 50 years. Children build healthy bodies through age-appropriate training, adults and seniors maintain their fitness, and women learn practical self-defense — with instruction tailored to each. We also run classes for students not attending school and welcome international members, providing an environment where anyone can train with confidence.</p>
          </div>
        </div>
      </div>

      <div class="cards-who__container">
        <div class="section__title-area">
          <span class="section-label">CLASSES</span>
          <div class="section-title">What We Teach</div>
        </div>
        <div class="cards-who__card-box">
          <div class="cards-who__card fade-up-in">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/assets/images/icon_for-kids.png" alt="Icon for children's development classes"><h3 class="cards-who__card-title">Supporting Children's Growth</h3></div>
              <div class="cards-who__card-bottom"><p class="text">Exercise matched to each stage of development builds fitness, focus, and courtesy.</p></div>
          </div>
          <div class="cards-who__card fade-up-in">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/assets/images/icon_for-health.png" alt="Icon for health and fitness training"><h3 class="cards-who__card-title">Health & Fitness</h3></div>
              <div class="cards-who__card-bottom"><p class="text">Safe for seniors and beginners. Full-body exercise and breathing you can sustain at your own pace.</p></div>
          </div>
          <div class="cards-who__card fade-up-in">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/assets/images/icon_for-everyone.png" alt="Icon for classes open to everyone"><h3 class="cards-who__card-title">Open to Everyone</h3></div>
              <div class="cards-who__card-bottom"><p class="text">Support classes for students not attending school, international members welcome — train with peace of mind.</p></div>
          </div>
          <div class="cards-who__card fade-up-in">
              <div class="cards-who__card-top"><img class="cards-who__card-icon" src="/assets/images/icon_for-resilience.png" alt="Icon for self-defense and mental resilience"><h3 class="cards-who__card-title">Self-Defense & Resilience</h3></div>
              <div class="cards-who__card-bottom"><p class="text">Practical self-defense and an unbreakable spirit, for women and students especially.</p></div>
          </div>
        </div>
      </div>
  </section>

  <div class="membership__cta-banner u-mt-60">
    <h2 class="membership__cta-title">Start with a Free Trial</h2>
    <p>
      Direct-affiliated classes offer free trial lessons. Just come along in comfortable clothing.
    </p>
    <a href="#contact"><div class="fv-btn-primary">Book a Free Trial</div></a>
  </div>

  <section class="top-section">
    <div class="top-section__container -reverse">
      <img class="top-section__kv-img fade-right-in" src="/assets/images/bg_schedule.jpg" alt="Iaido practice with instructors kneeling in seiza">
      <div class="section__title-area">
        <span class="section-label">SCHEDULE</span>
        <div class="section-title">Schedule</div>
        <a href="/en/schedule/"><div class="fv-btn-primary">View Schedule</div></a>
        <p class="text">Training schedules for Seishinkai karate dojos and classes in Sapporo and across Hokkaido. Check practice dates, event plans, and class cancellations at any time.</p>
      </div>

    </div>
        <div class="top-section__container">
      <img class="top-section__kv-img fade-left-in" src="/assets/images/bg_dojos.jpg" alt="Exterior of the Seishinkan headquarters karate dojo in Sapporo">
      <div class="section__title-area">
        <span class="section-label">DOJO LIST</span>
        <div class="section-title">Dojo List</div>
        <a href="/en/dojo/"><div class="fv-btn-primary">View Dojo List</div></a>
        <p class="text">A guide to the certified and affiliated dojos of the Seishinkai Karate Federation — locations in Sapporo, across Hokkaido, and overseas.</p>
      </div>

    </div>
        <div class="top-section__container -reverse">
      <img class="top-section__kv-img fade-right-in" src="/assets/images/bg_instructors.jpg" alt="Group photo of Seishinkai instructors and black belts">
      <div class="section__title-area">
        <span class="section-label">INSTRUCTORS</span>
        <div class="section-title">Instructors</div>
        <a href="/en/instructors/"><div class="fv-btn-primary">Meet Our Instructors</div></a>
        <p class="text">Meet the masters and instructors of Seishinkai — profiles of the teachers responsible for each dojo and their areas.</p>
      </div>

    </div>
        <div class="top-section__container">
      <img class="top-section__kv-img fade-left-in" src="/assets/images/bg_membership.jpg" alt="Dan certificate presentation at the headquarters dojo">
      <div class="section__title-area">
        <span class="section-label">MEMBERSHIP</span>
        <div class="section-title">Membership</div>
        <a href="/en/membership/"><div class="fv-btn-primary">Learn More</div></a>
        <p class="text">Seishinkai karate is open to children and adults of any age or experience. Find out how to join, what it costs, and how to book a free trial.</p>
      </div>

    </div>
    <div class="top-section__container -reverse">
      <img class="top-section__kv-img fade-right-in" src="/assets/images/img_news.jpg" alt="Seishinkai members celebrating together at the dojo">
      <div class="section__title-area">
        <span class="section-label">NEWS</span>
        <div class="section-title">News & SNS</div>
        <a href="/en/news/"><div class="fv-btn-primary">View News & SNS</div></a>
        <p class="text">Seishinkai publishes its latest updates on social media, blogs, and the bulletin board — event schedules, training reports, and class cancellation notices all in one place.</p>
      </div>
    </div>

    <div class="top-section__container">
      <img class="top-section__kv-img fade-left-in" src="/assets/images/img_links.jpg" alt="Organizations and partners supporting Seishinkai">
      <div class="section__title-area">
        <span class="section-label">LINKS & PARTNERS</span>
        <div class="section-title">Links & Partners</div>
        <a href="/en/links-partners/"><div class="fv-btn-primary">View Links & Partners</div></a>
        <p class="text">
          Explore the organizations, supporting companies, partner dojos, and official social media and blogs that help connect and support the Seishinkai community.
        </p>
      </div>
    </div>

    </div>
  </section>

  <ContactSection lang="en" />

</BaseLayout>
