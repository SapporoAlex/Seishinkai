---
import Button from "@components/buttons/Button.astro";
import ArrowRight from "@components/buttons/ArrowRight.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import data from 'src/data/cards-who.en.json';
const cards = data.cards;
---

<BaseLayout title="Welcome" lang="en" path="/">
  <section class="fv" id="fv">
    <div class="swiper-container">
      <div class="swiper-wrapper">
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_01.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_02.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_03.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_04.jpg" alt="" />
              </div>
            </div>
            <div class="swiper-slide fv__slide">
              <div class="fv__slide-bg">
                <img src="/seishinkai/assets/images/img_training_05.jpg" alt="" />
              </div>
            </div>
          </div>
      <div class="fv__overlay"></div>
      <div class="fv__text">
        <h1 class="fv__title">Seishinkai</h1>
        <p class="fv__copy">Karate for Modern Life<br>Health. <br class="u-sp-visible">Discipline. <br class="u-sp-visible">Self-Defense.</p>
        <a href="#contact">
          <button class='button-inverse'>
            <span class="button__label">Free trial</span>
            <ArrowRight />
          </button>
        </a>
      </div>
    </div>
  </section>

  <section class="cards-who" id="cards-who">
      <div class="cards-who__container">
        <img class="cards-who__top-img" src="/seishinkai/assets/images/logo.svg" alt="">
          <h2 class="cards-who__title">Seishinkai</h2>
          <p class="cards-who__text">Seishinkai is a traditional karate dojo that values personal growth, physical well-being, and health over competition.
          For more than 50 years, we have been active mainly in Sapporo, welcoming students from ages 3 to 83.
          For children, karate supports healthy physical development and discipline.
          For adults and seniors, it provides a way to maintain fitness and overall well-being.
          For women, it offers practical self-defense skills.
          We provide instruction tailored to each individual’s age and goals, while also offering classes for students who are not currently attending school and welcoming international participants.
          Our dojo is a place where everyone can learn and train with confidence in a safe and supportive environment.</p>
          <a href="https://seishinkan.ne.jp/profile.html"><Button>Learn more</Button></a>
          <div class="cards-who__card-box">
            <div class="cards-who__card" style="background-image: url('/seishinkai/assets/images/img_why_01.png')">
                <div class="cards-who__card-overlay"></div>
                <div class="cards-who__card-content">
                    <h2 class="cards-who__card-title">{ cards.card01.title }</h2>
                    <p class="cards-who__card-text">{ cards.card01.text }</p>
                </div>
            </div>
            <div class="cards-who__card" style="background-image: url('/seishinkai/assets/images/img_why_02.png')">
                <div class="cards-who__card-overlay"></div>
                <div class="cards-who__card-content">
                    <h2 class="cards-who__card-title">{ cards.card02.title }</h2>
                    <p class="cards-who__card-text">{ cards.card02.text }</p>
                </div>
            </div>
            <div class="cards-who__card" style="background-image: url('/seishinkai/assets/images/img_why_03.png')">
                <div class="cards-who__card-overlay"></div>
                <div class="cards-who__card-content">
                    <h2 class="cards-who__card-title">{ cards.card03.title }</h2>
                    <p class="cards-who__card-text">{ cards.card03.text }</p>
                </div>
            </div>
            <div class="cards-who__card" style="background-image: url('/seishinkai/assets/images/img_why_04.png')">
                <div class="cards-who__card-overlay"></div>
                <div class="cards-who__card-content">
                    <h2 class="cards-who__card-title">{ cards.card04.title }</h2>
                    <p class="cards-who__card-text">{ cards.card04.text }</p>
                </div>
            </div>
        </div>
      </div>
  </section>

  <section class="top-cards__section">
    <div class="layout__container">
      <div class="top-cards__grid">
        <a class="top-cards__link" href="https://seishinkan.ne.jp/keiko.html">
          <div class="top-cards__card">
            <img class="top-cards__image" src="/seishinkai/assets/images/icon_schedule.png">
            <h2>Schedule</h2>
          </div>
        </a>

        <a class="top-cards__link" href="https://seishinkan.ne.jp/schedule.html">
          <div class="top-cards__card">
            <img class="top-cards__image" src="/seishinkai/assets/images/icon_dojo.png">
            <h2>Dojos</h2>
          </div>
        </a>

        <a class="top-cards__link" href="https://seishinkan.ne.jp/manifesto.html">
          <div class="top-cards__card">
            <img class="top-cards__image" src="/seishinkai/assets/images/icon_instructors.png">
            <h2>Instructors</h2>
          </div>
        </a>

        <a class="top-cards__link" href="https://seishinkan.ne.jp/schedule2.html">
          <div class="top-cards__card">
            <img class="top-cards__image" src="/seishinkai/assets/images/icon_join.png">
            <h2>Membership</h2>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="top-contact" id="contact">

    <div class="layout__container">
      <div class="top-contact__contact-header">
        <span>CONTACT</span>
        <h2>Trial Class Registration & Contact</h2>
        <p>Please contact us here to apply for a trial karate class at Seishinkai.</p>
      </div>

      <div class="top-contact__contact-grid">

        <!-- Phone -->
        <div class="top-contact__contact-card highlight">
          <div class="top-contact__icon">☎</div>
          <h3>Phone</h3>
          <p class="top-contact__big">011-300-0048</p>
          <small>Mon & Thu 1:00–4:00 PM / Tue, Thu & Fri 1:00–3:00 PM</small>
        </div>

        <!-- Email -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">✉</div>
          <h3>Email</h3>
          <p class="top-contact__email">Karate@seishinkan.ne.jp</p>
          <small>Available 24/7</small>
        </div>

        <!-- Fax -->
        <div class="top-contact__contact-card">
          <div class="top-contact__icon">📠</div>
          <h3>Fax</h3>
          <p>011-300-0094</p>
        </div>

        <!-- QR -->
        <div class="top-contact__contact-card top-contact__qr-card">
          <img src="/seishinkai/assets/images/img_qr_volunteer.jpg" alt="お問い合わせQRコード">
          <p>Easy contact from your smartphone</p>
        </div>

      </div>


      <div class="top-contact__contact-info">
        <div>
          <h4>Office Hours</h4>
          <p>Monday–Friday 1:00–3:00 PM</p>
        </div>

        <div>
          <h4>Location</h4>
          <p>2-1-27 Sakaedori, Shiroishi-ku, Sapporo (Along Tohoku-dori)</p>
        </div>
      </div>

      <div class="top-contact__notice-box">
        <strong>Please Note</strong>
        <p>
          Our office is staffed on a rotating schedule, so phone calls may not always be answered during office hours.
          If you are unable to reach us, please contact us by email.
        </p>
      </div>
    </div>
  </section>

</BaseLayout>
