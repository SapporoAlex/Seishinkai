  会社員: "Company employee",
  コンサルタント: "Consultant",
  "定年/司法書士": "Retired (judicial scrivener)",
  及川写真事務所: "Oikawa Photo Office",
  主婦: "Homemaker",
  団体職員: "Organization staff",
  "ラ･ビエス": "La Piece",
  教師: "Teacher",
  神学教師: "Theology teacher",
  "定年/北電": "Retired (Hokkaido Electric)",
  学生: "Student",
};

const TAGS: Record<string, string> = {
  英語: "English",
  イタリア語: "Italian",
  帰国中: "Currently abroad",
};

const DETAILS: Record<string, string> = {
  清心館総本部二代目館長: "2nd Director of the Seishinkan Headquarters",
