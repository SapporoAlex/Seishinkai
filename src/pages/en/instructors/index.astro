const SECTION_TITLES: Record<string, string> = {
  "ISKF全日本清心会空手道連盟 名誉範士":
    "ISKF All Japan Seishinkai Karate Federation — Honorary Hanshi",
  "ISKF全日本清心会空手道連盟 支部長・師範・指導員":
    "ISKF All Japan Seishinkai Karate Federation — Masters, Branch Chiefs & Instructors",
};

const GROUP_TITLES: Record<string, string> = {
  "専任/師範・部長": "Full-time / Masters & Division Heads",
  指導員: "Instructors",
  "内弟子・内弟子見習い": "Uchideshi (Live-in Students) & Trainees",
  "師範・支部長・指導員・助教":
    "Masters, Branch Chiefs, Instructors & Assistants",
};

const NOTES: Record<string, string> = {
  "※各師範・支部長は就労後、ボランティア指導員として清心会活動に参加しています(順不同)":
    "※ Masters and branch chiefs take part in Seishinkai activities as volunteer instructors outside their regular work (in no particular order)",
  "※各師範・支部長は就労後、ボランティアとして清心会活動に参加しています(順不同)":
    "※ Masters and branch chiefs take part in Seishinkai activities as volunteers outside their regular work (in no particular order)",
  "※すべての有段者、指導員等を掲載しているわけではありません。掲載は順不同です。":
    "※ Not all dan holders and instructors are listed. Listing is in no particular order.",
};

const DAN_RANKS: Record<string, string> = {
  初段: "1st Dan",
  弐段: "2nd Dan",
  参段: "3rd Dan",
  四段: "4th Dan",
  五段: "5th Dan",
  六段: "6th Dan",
  七段: "7th Dan",
  八段: "8th Dan",
};

const t = (dict: Record<string, string>, value: string) =>
  value ? (dict[value] ?? value) : value;
---

<BaseLayout
  title="Instructors"
  description="Meet the shihan, branch chiefs, and instructors of Seishinkai Karate leading our dojos across Hokkaido, Japan."
  lang="en"
  path="/en/instructors/"
>
  <section class="instructors">
    <div class="page-container">
      <div class="section__title-area">
        <span class="section-label">INSTRUCTORS</span>
        <h1 class="section-title">Masters & Branch Chiefs</h1>
      </div>

      {
        sections.map((section) => (
          <div class="instructors__category">
            <h2 class="instructors__category-title">
              {t(SECTION_TITLES, section.title)}
            </h2>

            {section.groups.map((group) => (
              <div class="instructors__group">
                {group.title && (
                  <h3 class="instructors__subsection-title">
                    {t(GROUP_TITLES, group.title)}
                  </h3>
                )}
                {group.note && (
                  <p class="instructors__note">{t(NOTES, group.note)}</p>
                )}

                <div class="instructors__grid">
                  {group.members.map((member) => (
                    <ProfileCard
                      id={member.id}
                      image={member.image}
                      name={t(NAMES, member.name)}
                      role={t(ROLES, member.role)}
                      position={t(POSITIONS, member.position)}
                      date={member.date}
                      prefecture={t(PREFECTURES, member.prefecture)}
                      profession={t(PROFESSIONS, member.profession)}
                      details={member.details.map((d) => t(DETAILS, d))}
                      tags={member.tags.map((tag) => t(TAGS, tag))}
                      lang="en"
                    />
                  ))}
                </div>
              </div>
            ))}
          </div>
        ))
      }

      <p class="instructors__note">
        ※ Instructor names without a verified English spelling are shown in Japanese.
      </p>

      <div class="instructors__belt-levels">
        <h2 class="instructors__category-title">
          Registered Dan Holders (as of May 8, 2022)
        </h2>

        <table class="instructors__dan-table">
          <tbody>
            <tr>
              {beltLevels.danRanks.map((rank) => <th>{t(DAN_RANKS, rank.rank)}</th>)}
            </tr>
            <tr>
              {beltLevels.danRanks.map((rank) => <td>{rank.count}</td>)}
            </tr>
          </tbody>
        </table>

        <h3 class="instructors__subsection-title">Associate & Partner Dojos</h3>
        <table class="table">
          <tbody>
            <tr>
              <th>Aozorakai Karate</th>
              <td>Chiba / Muryu-juku</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
